# Copy this file to .env and fill values for local testing

# Telegram bot token
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Multilingotrain_bot

# Gemini / Google GenAI API key (optional)
GEMINI_API_KEY=

# Path to SQLite DB (defaults to ./users.db)
DB_PATH=./users.db

# Public URL of the app (used by bot). For local testing use http://localhost:8000
APP_URL=http://localhost:8000

# Mock train API base URL
MOCK_API_URL=http://127.0.0.1:5001/api

# Port for the FastAPI app (Render sets PORT automatically)
PORT=8000
